<!-- LEADERSHIP -->
<section id="about-leadership" class="section section--accent-left">
  <div class="content-wrapper wrapper--narrow">
    <h2>Leadership</h2>

<div class="leadership-layout">
  <div class="leadership-photo">
    <img src="/assets/img/raphael-heeb.jpg" alt="Raphael Heeb — Founder of VAIRA Technology" loading="lazy">
  </div>

  <div class="leadership-text">
    <h3>Raphael Heeb – Founder</h3>
    <p>
      Raphael combines deep technical expertise with entrepreneurial experience and international
      industry exposure. Before founding VAIRA Technology, he led the development and
      industrialization of advanced manufacturing technologies, built global partnerships, and
      supported deep‑tech companies from concept to market launch.
    </p>
    <ul>
      <li>Founder & CEO of NematX AG, an ETH spin‑off pioneering LCP 3D printing</li>
      <li>Leadership roles at Optics Balzers AG, a deep-tech SME specialized in optical coatings and precision components</li>
      <li>PhD in Materials Science (ETH Zurich) and Executive MBA (University of St. Gallen, HSG)</li>
    </ul>
  </div>
</div>
    
</section>

